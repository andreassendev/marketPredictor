# LLM API-konfigurasjon (støtter alle LLM-APIer med OpenAI SDK-format)
# Alternativer: OpenRouter (openrouter.ai), Groq (groq.com), OpenAI, Qwen
# Tips: Start med <40 simuleringsrunder for å holde kostnadene nede
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=google/gemini-flash-2.0

# ===== Zep Cloud (agent-minne) =====
# Gratis tier holder for testing: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Akselerasjons-LLM (valgfritt) =====
# Fjern disse linjene hvis du ikke bruker akselerasjon
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
